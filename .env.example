# sportsml local environment
# Copy to .env and fill in. .env is gitignored.

# --- Backend ---
SPORTSML_DATA_DIR=./data
SPORTSML_DUCKDB_PATH=./data/sportsml.duckdb
SPORTSML_TENANT_ID=demo
SPORTSML_DEFAULT_SPORT=basketball.nba

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Dagster ---
DAGSTER_HOME=./.dagster_home
DAGSTER_WEBSERVER_PORT=3001

# --- nba_api ---
# nba_api uses stats.nba.com (no key required); these tune behavior
NBA_API_TIMEOUT=30
NBA_API_RETRIES=3
NBA_API_DELAY_S=0.6
